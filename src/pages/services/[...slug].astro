---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Image from "@components/ui/images/Image.astro";
import { SITE } from "@/config";
import "@fancyapps/ui/dist/fancybox/fancybox.css";
import Icon from "@/components/ui/icons/icon.astro";

export async function getStaticPaths() {
    const posts = await getCollection("posts");
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: post,
    }));
}

const post = Astro.props;
const { Content } = await post.render();

const URL = Astro.url.href;
const ogImage = post.data.ogImage;

const posts = await getCollection("posts");
const currentIndex = posts.findIndex((p) => p.slug === post.slug);
const prevPost = posts[currentIndex - 1];
const nextPost = posts[currentIndex + 1];
---

<BaseLayout
    title={post.data.title}
    description={post.data.description}
    ogImage={ogImage}
    structuredData={{
        "@context": "https://schema.org",
        "@type": "NewsArticle",
        "@id": URL,
        url: URL,
        description: post.data.description,
        image: [
            // post.data.banner,
        ],
        headline: post.data.title,
        datePublished: post.data.pubDate,
        dateModified: post.data.pubDate,
        author: [
            {
                "@type": "Person",
                name: SITE.author,
                url: SITE.url,
            },
        ],
    }}
>
    <section class="mx-auto max-w-6xl px-4 pb-16 pt-8 sm:px-6 lg:px-8 lg:pt-12">
        <div
            class="bg-white border border-tertiary rounded-3xl overflow-hidden shadow-sm dark:bg-neutral-900/40 dark:border-neutral-800"
        >
            <div class="max-w-6xl">
                <Image
                    class="w-full h-[300px] md:h-[500px] object-cover"
                    src={post.data.banner}
                    alt={post.data.title}
                    draggable="false"
                    format="avif"
                    loading="lazy"
                    inferSize={true}
                />
            </div>
            <div class="px-6 py-12 md:px-16 lg:px-20">
                <div class="mb-12 text-center">
                    <h1
                        class="text-3xl font-bold text-primary dark:text-neutral-100 md:text-5xl lg:text-6xl uppercase tracking-tight"
                    >
                        {post.data.title}
                    </h1>
                    <div
                        class="mt-6 h-1.5 w-24 bg-secondary mx-auto rounded-full"
                    >
                    </div>
                    <p
                        class="mt-8 text-xl text-neutral-600 dark:text-neutral-300 leading-relaxed max-w-3xl mx-auto"
                    >
                        {post.data.description}
                    </p>
                </div>

                <article
                    class="prose prose-blog sm:prose-lg dark:prose-invert max-w-none content"
                >
                    <div
                        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"
                    >
                        <Content />
                    </div>
                </article>

                <div
                    class="flex items-center justify-between mt-16 pt-8 border-t border-tertiary/30 dark:border-neutral-800/50"
                >
                    {
                        prevPost ? (
                            <a
                                href={`/services/${prevPost.slug}`}
                                class="group flex items-center gap-x-3 text-primary hover:text-secondary transition-colors duration-300"
                            >
                                <div class="p-3 bg-tertiary/30 rounded-full group-hover:bg-secondary/20">
                                    <Icon
                                        name="arrowLeft"
                                        class="h-5 w-5 transition duration-300 group-hover:-translate-x-1"
                                    />
                                </div>
                                <div class="hidden sm:flex flex-col">
                                    <span class="text-xs uppercase tracking-widest text-neutral-500 font-bold">
                                        Anterior
                                    </span>
                                    <span class="font-bold uppercase tracking-tighter">
                                        {prevPost.slug
                                            .slice(2)
                                            .replaceAll("-", " ")}
                                    </span>
                                </div>
                            </a>
                        ) : (
                            <div />
                        )
                    }

                    {
                        nextPost && (
                            <a
                                href={`/services/${nextPost.slug}`}
                                class="group flex items-center gap-x-3 text-right text-primary hover:text-secondary transition-colors duration-300"
                            >
                                <div class="hidden sm:flex flex-col">
                                    <span class="text-xs uppercase tracking-widest text-neutral-500 font-bold">
                                        Siguiente
                                    </span>
                                    <span class="font-bold uppercase tracking-tighter">
                                        {nextPost.slug
                                            .slice(2)
                                            .replaceAll("-", " ")}
                                    </span>
                                </div>
                                <div class="p-3 bg-tertiary/30 rounded-full group-hover:bg-secondary/20">
                                    <Icon
                                        name="arrowRight"
                                        class="h-5 w-5 transition duration-300 group-hover:translate-x-1"
                                    />
                                </div>
                            </a>
                        )
                    }
                </div>
            </div>
        </div>
    </section>
    <style is:inline>
        html.dark .astro-code,
        html.dark .astro-code span {
            color: var(--shiki-dark) !important;
            background-color: var(--shiki-dark-bg) !important;
        }
        .prose img {
            margin: 0 !important;
            border-radius: 0.75rem;
        }
        .prose p {
            margin: 0;
        }
        .thumbnail {
            cursor: pointer;
            transition: transform 0.3s ease;
        }
        .thumbnail:hover {
            transform: scale(1.05);
        }
        .flex-grow {
            flex-grow: 1;
        }
    </style>
</BaseLayout>

<script>
    import { Fancybox } from "@fancyapps/ui";

    function initializeFancybox() {
        Fancybox.bind("[data-fancybox]", {});
    }

    function addFancyboxAttributes() {
        const contentElement = document.querySelector(".content");
        if (contentElement) {
            const images = contentElement.querySelectorAll("img");
            images.forEach((img) => {
                img.setAttribute("data-fancybox", "gallery");
                img.classList.add("thumbnail");
            });
        }
    }

    document.addEventListener("DOMContentLoaded", () => {
        addFancyboxAttributes();
        initializeFancybox();
    });
</script>
