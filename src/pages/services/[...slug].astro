---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Image from "@components/ui/images/Image.astro";
import { SITE } from "@/config";
import "@fancyapps/ui/dist/fancybox/fancybox.css";
import Icon from "@/components/ui/icons/icon.astro";

// Import Swiper styles
import 'swiper/css';
import 'swiper/css/effect-creative';
import 'swiper/css/pagination';

export async function getStaticPaths() {
    const posts = await getCollection("posts");
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: post,
    }));
}

const post = Astro.props;
const { Content } = await post.render();

const URL = Astro.url.href;
const ogImage = post.data.ogImage;

const posts = await getCollection("posts");
const currentIndex = posts.findIndex((p) => p.slug === post.slug);
const prevPost = posts[currentIndex - 1];
const nextPost = posts[currentIndex + 1];

// Extract gallery images
const images = import.meta.glob<{ default: ImageMetadata }>("/src/images/services/**/*.{jpeg,jpg,png,gif,webp,avif}");

// Determine the service folder
// 1. Try to get it from the raw body markdown
const bodyFolderMatch = post.body.match(/@images\/services\/(.*?)\//);
let folderName = bodyFolderMatch ? bodyFolderMatch[1] : "";

// 2. Fallback to banner path if not found in body
if (!folderName) {
    const bannerPath = (post.data.banner as any).src || post.data.banner.toString();
    const folderMatch = bannerPath.match(/services\/(.*?)\//);
    if (folderMatch) folderName = folderMatch[1];
}

const serviceImagesPromises = Object.entries(images)
    .filter(([path]) => folderName && path.includes(`/services/${folderName}/`))
    .map(([_, importFn]) => importFn());

const resolvedImages = await Promise.all(serviceImagesPromises);
// Map to the default export and filter out potential undefined values
const gallery = resolvedImages.map(img => img?.default).filter(Boolean);

// If no gallery images found, fallback to banners
const finalGallery = gallery.length > 0 ? gallery : [post.data.banner, post.data.banner2].filter(Boolean);
---

<BaseLayout
    title={post.data.title}
    description={post.data.description}
    ogImage={ogImage}
    structuredData={{
        "@context": "https://schema.org",
        "@type": "NewsArticle",
        "@id": URL,
        url: URL,
        description: post.data.description,
        image: [
            // post.data.banner,
        ],
        headline: post.data.title,
        datePublished: post.data.pubDate,
        dateModified: post.data.pubDate,
        author: [
            {
                "@type": "Person",
                name: SITE.author,
                url: SITE.url,
            },
        ],
    }}
>
    <section class="mx-auto max-w-6xl px-4 pb-16 pt-8 sm:px-6 lg:px-8 lg:pt-12">
        <!-- Gallery Section -->
        <div class="gallery-section relative mb-16" data-total={finalGallery.length}>
            <!-- Background glow -->
            <div class="absolute inset-0 -inset-x-12 bg-gradient-to-b from-primary/5 via-secondary/5 to-transparent dark:from-primary/10 dark:via-secondary/5 dark:to-transparent rounded-[3rem] blur-2xl pointer-events-none"></div>

            <!-- Slide Counter -->
            <div class="relative z-10 flex items-center justify-center gap-3 mb-8 pt-4">
                <span class="text-xs font-bold text-secondary uppercase tracking-[0.3em]">{post.data.title}</span>
                <span class="text-neutral-300 dark:text-neutral-600">|</span>
                <span class="slide-counter text-xs font-bold text-neutral-400 dark:text-neutral-500 uppercase tracking-[0.3em] tabular-nums">
                    01 / {finalGallery.length.toString().padStart(2, '0')}
                </span>
            </div>

            <!-- Main Swiper -->
            <div class="swiper service-swiper relative max-w-5xl mx-auto py-6 overflow-visible">
                <div class="swiper-wrapper">
                    {finalGallery.map((img, idx) => {
                        if (!img) return null;
                        return (
                        <div class="swiper-slide !flex items-center justify-center">
                            <div class="slide-card group/card relative w-full h-full rounded-[32px] border border-white/15 dark:border-white/10 overflow-hidden bg-neutral-900 shadow-[0_30px_60px_-15px_rgba(39,78,134,0.3)] dark:shadow-[0_30px_60px_-15px_rgba(0,0,0,0.6)]">
                                <!-- Fancybox anchor wrapping the image and button -->
                                <a
                                    href={(img as any).src || img.toString()}
                                    data-fancybox="service-gallery"
                                    data-caption={`${post.data.title} — ${(idx + 1).toString().padStart(2, '0')} / ${finalGallery.length.toString().padStart(2, '0')}`}
                                    class="block w-full h-full relative group/anchor"
                                    aria-label={`Ver imagen ${idx + 1} en pantalla completa`}
                                >
                                    <Image
                                        class="w-full h-full object-cover transition-transform duration-700 group-hover/card:scale-[1.03]"
                                        src={img}
                                        alt={`${post.data.title} - Imagen ${idx + 1}`}
                                        draggable="false"
                                        format="avif"
                                        loading={idx < 3 ? "eager" : "lazy"}
                                    />
                                    <!-- Gradient overlay for depth on inactive slides -->
                                    <div class="slide-overlay absolute inset-0 bg-gradient-to-t from-primary/60 via-transparent to-transparent opacity-0 transition-opacity duration-700 pointer-events-none"></div>
                                    <!-- Image number badge -->
                                    <div class="absolute top-5 right-5 px-3 py-1.5 bg-black/40 backdrop-blur-md rounded-full text-[10px] font-bold text-white/80 uppercase tracking-widest pointer-events-none">
                                        {(idx + 1).toString().padStart(2, '0')}
                                    </div>
                                    <!-- Expand / Fullscreen button (visible on hover) -->
                                    <div
                                        class="absolute bottom-5 right-5 flex items-center gap-1.5 px-3 py-2 rounded-xl bg-black/50 dark:bg-white/10 backdrop-blur-md border border-white/20 text-white text-xs font-bold uppercase tracking-wider opacity-0 translate-y-2 group-hover/card:opacity-100 group-hover/card:translate-y-0 transition-all duration-300 hover:bg-secondary/80 hover:border-secondary/50"
                                    >
                                        <!-- Expand icon -->
                                        <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 8V6a2 2 0 012-2h2M4 16v2a2 2 0 002 2h2m8-16h2a2 2 0 012 2v2m0 8v2a2 2 0 01-2 2h-2"/>
                                        </svg>
                                        <span class="hidden sm:inline">Ver completa</span>
                                    </div>
                                </a>
                            </div>
                        </div>
                    );})}
                </div>

                <!-- Pagination -->
                <div class="swiper-pagination !relative !mt-8"></div>
            </div>

            <!-- Autoplay progress bar -->
            <div class="autoplay-progress mx-auto max-w-xs mt-4">
                <div class="h-0.5 bg-neutral-200 dark:bg-neutral-800 rounded-full overflow-hidden">
                    <div class="progress-fill h-full bg-gradient-to-r from-primary to-secondary rounded-full transition-none" style="width: 0%"></div>
                </div>
            </div>

            <!-- Thumbnail Strip -->
            <div class="swiper service-thumbs mt-6 max-w-3xl mx-auto px-2">
                <div class="swiper-wrapper !flex !items-center justify-center gap-2">
                    {finalGallery.map((img, idx) => (
                        <div class="swiper-slide !w-auto cursor-pointer">
                            <div class="thumb-card relative rounded-xl overflow-hidden border-2 border-transparent transition-all duration-300 hover:border-secondary/60">
                                <Image
                                    class="block w-16 h-16 sm:w-20 sm:h-20 object-cover transition-transform duration-300 hover:scale-105"
                                    src={img}
                                    alt={`${post.data.title} miniatura ${idx + 1}`}
                                    draggable="false"
                                    format="avif"
                                    loading="lazy"
                                    width={80}
                                    height={80}
                                />
                                <!-- Active overlay -->
                                <div class="thumb-overlay absolute inset-0 bg-primary/20 opacity-0 transition-opacity duration-300"></div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>

        <!-- Service Info Card -->
        <div class="relative overflow-hidden rounded-[2.5rem] border border-neutral-200/80 dark:border-neutral-700/50 bg-white dark:bg-neutral-900/60 shadow-[0_8px_40px_-12px_rgba(39,78,134,0.15)] dark:shadow-[0_8px_40px_-12px_rgba(0,0,0,0.4)]">

            <!-- Top gradient band -->
            <div class="h-1.5 w-full bg-gradient-to-r from-primary via-secondary to-primary/60"></div>

            <!-- Decorative background orb -->
            <div class="absolute -top-24 -right-24 w-64 h-64 rounded-full bg-secondary/5 dark:bg-secondary/10 blur-3xl pointer-events-none"></div>
            <div class="absolute -bottom-16 -left-16 w-48 h-48 rounded-full bg-primary/5 dark:bg-primary/10 blur-3xl pointer-events-none"></div>

            <div class="relative px-6 py-14 md:px-16 lg:px-20">

                <!-- Category Badge -->
                <div class="flex justify-center mb-8">
                    <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-secondary/10 dark:bg-secondary/15 border border-secondary/20 rounded-full text-xs font-bold text-secondary uppercase tracking-[0.2em]">
                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M15.5 6.5l-1.5 1.5 2 2-5 5-2-2-1.5 1.5 2 2-3.5 3.5 1.5 1.5 3.5-3.5 2 2 1.5-1.5-2-2 5-5 2 2 1.5-1.5-2-2 1.5-1.5zM18 2l-3 3 1 1-7 7-1-1-3 3 4 4 3-3-1-1 7-7 1 1 3-3z"/>
                        </svg>
                        Servicio Profesional
                    </span>
                </div>

                <!-- Title -->
                <div class="text-center mb-10">
                    <h1 class="text-3xl font-black text-primary dark:text-white md:text-5xl lg:text-6xl uppercase tracking-widest leading-[1.1]">
                        {post.data.title}
                    </h1>
                    <!-- Animated underline -->
                    <div class="mt-5 mx-auto flex items-center justify-center gap-2">
                        <div class="h-px w-16 bg-gradient-to-r from-transparent to-secondary/60"></div>
                        <div class="h-1.5 w-10 rounded-full bg-gradient-to-r from-primary to-secondary"></div>
                        <div class="h-px w-16 bg-gradient-to-l from-transparent to-secondary/60"></div>
                    </div>
                </div>

                <!-- Description -->
                <p class="text-lg md:text-xl text-neutral-600 dark:text-neutral-300 leading-relaxed max-w-2xl mx-auto text-center">
                    {post.data.description}
                </p>

                <!-- Divider with icon -->
                <div class="flex items-center gap-4 my-10">
                    <div class="flex-1 h-px bg-gradient-to-r from-transparent via-neutral-200 dark:via-neutral-700 to-transparent"></div>
                    <div class="p-2 rounded-full bg-secondary/10 dark:bg-secondary/15 border border-secondary/20">
                        <svg class="w-4 h-4 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-6.836m0 0a3.5 3.5 0 004.95-4.95l-1.172 1.172m-2.122-2.122L9.876 7.515m2.122 2.122L9.876 7.515m2.122 2.122a3.5 3.5 0 00-4.95 4.95"/>
                        </svg>
                    </div>
                    <div class="flex-1 h-px bg-gradient-to-r from-transparent via-neutral-200 dark:via-neutral-700 to-transparent"></div>
                </div>

                <!-- Prev / Next Navigation -->
                <div class="grid grid-cols-2 gap-4">
                    {prevPost ? (
                        <a
                            href={`/services/${prevPost.slug}`}
                            class="group relative flex items-center gap-3 p-4 rounded-2xl border border-neutral-100 dark:border-neutral-800 bg-neutral-50/80 dark:bg-neutral-800/50 hover:border-secondary/40 hover:bg-secondary/5 dark:hover:bg-secondary/10 hover:shadow-md transition-all duration-300 overflow-hidden"
                        >
                            <!-- Hover gradient -->
                            <div class="absolute inset-0 bg-gradient-to-r from-secondary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
                            <!-- Arrow -->
                            <div class="relative flex-shrink-0 w-9 h-9 flex items-center justify-center rounded-xl bg-white dark:bg-neutral-700 border border-neutral-200 dark:border-neutral-600 group-hover:border-secondary/50 group-hover:bg-secondary/10 transition-all duration-300 shadow-sm">
                                <Icon name="arrowLeft" class="h-4 w-4 text-primary dark:text-white group-hover:text-secondary transition-all duration-300 group-hover:-translate-x-0.5" />
                            </div>
                            <!-- Text -->
                            <div class="relative min-w-0">
                                <span class="block text-[10px] uppercase tracking-[0.2em] text-neutral-400 dark:text-neutral-500 font-bold mb-0.5">Anterior</span>
                                <span class="block text-sm font-bold text-primary dark:text-neutral-200 group-hover:text-secondary transition-colors duration-300 truncate uppercase tracking-widest text-center w-full">
                                    {prevPost.slug.slice(2).replaceAll("-", " ")}
                                </span>
                            </div>
                        </a>
                    ) : (
                        <div></div>
                    )}

                    {nextPost ? (
                        <a
                            href={`/services/${nextPost.slug}`}
                            class="group relative flex items-center justify-end gap-3 p-4 rounded-2xl border border-neutral-100 dark:border-neutral-800 bg-neutral-50/80 dark:bg-neutral-800/50 hover:border-secondary/40 hover:bg-secondary/5 dark:hover:bg-secondary/10 hover:shadow-md transition-all duration-300 text-right overflow-hidden"
                        >
                            <!-- Hover gradient -->
                            <div class="absolute inset-0 bg-gradient-to-l from-secondary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
                            <!-- Text -->
                            <div class="relative min-w-0">
                                <span class="block text-[10px] uppercase tracking-[0.2em] text-neutral-400 dark:text-neutral-500 font-bold mb-0.5">Siguiente</span>
                                <span class="block text-sm font-bold text-primary dark:text-neutral-200 group-hover:text-secondary transition-colors duration-300 truncate uppercase tracking-widest text-center w-full">
                                    {nextPost.slug.slice(2).replaceAll("-", " ")}
                                </span>
                            </div>
                            <!-- Arrow -->
                            <div class="relative flex-shrink-0 w-9 h-9 flex items-center justify-center rounded-xl bg-white dark:bg-neutral-700 border border-neutral-200 dark:border-neutral-600 group-hover:border-secondary/50 group-hover:bg-secondary/10 transition-all duration-300 shadow-sm">
                                <Icon name="arrowRight" class="h-4 w-4 text-primary dark:text-white group-hover:text-secondary transition-all duration-300 group-hover:translate-x-0.5" />
                            </div>
                        </a>
                    ) : (
                        <div></div>
                    )}
                </div>

            </div>
        </div>
    </section>
    <style is:inline>
        html.dark .astro-code,
        html.dark .astro-code span {
            color: var(--shiki-dark) !important;
            background-color: var(--shiki-dark-bg) !important;
        }
        .prose img {
            margin: 0 !important;
            border-radius: 0.75rem;
        }
        .prose p {
            margin: 0;
        }
        .thumbnail {
            cursor: pointer;
            transition: transform 0.3s ease;
        }
        .thumbnail:hover {
            transform: scale(1.05);
        }

        /* ===== Gallery Swiper ===== */
        .service-swiper {
            width: 100%;
            perspective: 1200px;
        }

        .swiper-slide {
            width: 300px;
            height: 400px;
            transition: filter 0.5s ease;
        }
        @media (min-width: 640px) {
            .swiper-slide {
                width: 380px;
                height: 480px;
            }
        }
        @media (min-width: 1024px) {
            .swiper-slide {
                width: 480px;
                height: 560px;
            }
        }

        /* Active slide glow */
        .swiper-slide-active .slide-card {
            box-shadow:
                0 30px 60px -15px rgba(39, 78, 134, 0.35),
                0 0 40px -10px rgba(128, 204, 226, 0.15);
        }
        html.dark .swiper-slide-active .slide-card {
            box-shadow:
                0 30px 60px -15px rgba(0, 0, 0, 0.7),
                0 0 40px -10px rgba(128, 204, 226, 0.1);
        }

        /* Inactive slides get subtle overlay */
        .swiper-slide:not(.swiper-slide-active) .slide-overlay {
            opacity: 0.4;
        }

        /* Pagination dots */
        .swiper-pagination-bullet {
            width: 8px;
            height: 8px;
            background: #274e86 !important;
            opacity: 0.25;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        html.dark .swiper-pagination-bullet {
            background: #80cce2 !important;
            opacity: 0.25;
        }
        .swiper-pagination-bullet-active {
            opacity: 1;
            width: 28px !important;
            border-radius: 4px !important;
            background: linear-gradient(135deg, #274e86, #80cce2) !important;
            box-shadow: 0 0 12px rgba(128, 204, 226, 0.4);
        }

        /* Counter fade animation */
        .slide-counter {
            transition: opacity 0.3s ease;
        }
        .slide-counter.changing {
            opacity: 0;
        }

        /* ===== Thumbnail Swiper ===== */
        .service-thumbs {
            width: 100%;
        }
        .service-thumbs .swiper-slide {
            width: auto !important;
            height: auto !important;
            opacity: 0.45;
            filter: grayscale(0.3);
            transition: opacity 0.3s ease, filter 0.3s ease;
        }
        .service-thumbs .swiper-slide-thumb-active {
            opacity: 1;
            filter: grayscale(0);
        }
        .service-thumbs .swiper-slide-thumb-active .thumb-card {
            border-color: #80cce2;
            box-shadow: 0 0 0 1px #80cce2, 0 0 12px rgba(128, 204, 226, 0.35);
        }
        .service-thumbs .swiper-slide-thumb-active .thumb-overlay {
            opacity: 1;
        }
    </style>
</BaseLayout>

<script>
    import Swiper from 'swiper';
    import { EffectCreative, Pagination, Autoplay, Thumbs } from 'swiper/modules';
    import { Fancybox } from "@fancyapps/ui";

    let swiperInstance: Swiper | null = null;
    let thumbsInstance: Swiper | null = null;

    function initializeSwiper() {
        // Destroy previous instances if exist
        if (swiperInstance) {
            swiperInstance.destroy(true, true);
        }
        if (thumbsInstance) {
            thumbsInstance.destroy(true, true);
        }

        // Initialize thumbs Swiper first (required by Thumbs module)
        thumbsInstance = new Swiper('.service-thumbs', {
            modules: [],
            slidesPerView: 'auto',
            spaceBetween: 8,
            watchSlidesProgress: true,
            freeMode: true,
            centeredSlides: false,
        });

        const counterEl = document.querySelector('.slide-counter');
        const progressFill = document.querySelector('.progress-fill') as HTMLElement;

        swiperInstance = new Swiper('.service-swiper', {
            modules: [EffectCreative, Pagination, Autoplay, Thumbs],
            thumbs: { swiper: thumbsInstance },
            effect: 'creative',
            grabCursor: true,
            loop: true,
            centeredSlides: true,
            slidesPerView: 'auto',
            speed: 800,
            autoplay: {
                delay: 4000,
                disableOnInteraction: false,
                pauseOnMouseEnter: true,
            },
            creativeEffect: {
                perspective: true,
                limitProgress: 2,
                shadowPerProgress: true,
                prev: {
                    shadow: true,
                    translate: ['-105%', 0, -300],
                    rotate: [0, 12, 0],
                    scale: 0.85,
                    opacity: 0.5,
                    origin: 'right center',
                },
                next: {
                    shadow: true,
                    translate: ['105%', 0, -300],
                    rotate: [0, -12, 0],
                    scale: 0.85,
                    opacity: 0.5,
                    origin: 'left center',
                },
            },
            pagination: {
                el: '.swiper-pagination',
                clickable: true,
            },
            on: {
                slideChange: function(swiper) {
                    // Update counter with fade animation
                    if (counterEl) {
                        counterEl.classList.add('changing');
                        // Use realIndex for the current slide number
                        const realIndex = swiper.realIndex + 1;
                        // Use the data attribute for the total to be 100% accurate
                        const total = document.querySelector('.gallery-section')?.getAttribute('data-total') || '0';
                        
                        setTimeout(() => {
                            counterEl.textContent = `${realIndex.toString().padStart(2, '0')} / ${total.padStart(2, '0')}`;
                            counterEl.classList.remove('changing');
                        }, 200);
                    }
                },
                autoplayTimeLeft: function(_swiper, _timeLeft, percentage) {
                    // Update progress bar
                    if (progressFill) {
                        progressFill.style.width = `${(1 - percentage) * 100}%`;
                    }
                },
            }
        });
    }

    function initializeFancybox() {
        // Config for the main slide gallery
        Fancybox.bind('[data-fancybox="service-gallery"]', {
            animated: true,
            showClass: "f-fadeIn",
            hideClass: "f-fadeOut",
            Toolbar: {
                display: {
                    left: ["infobar"],
                    middle: [],
                    right: ["slideshow", "download", "fullscreen", "close"],
                },
            },
            caption: function (_fancybox, slide) {
                return slide.el?.getAttribute("data-caption") || "";
            },
            Images: {
                zoom: true,
            },
        });
        // Also bind any other data-fancybox elements (prose images, etc.)
        Fancybox.bind('[data-fancybox="gallery"]', {});
    }

    function addFancyboxAttributes() {
        const contentElement = document.querySelector(".content");
        if (contentElement) {
            const images = contentElement.querySelectorAll("img");
            images.forEach((img) => {
                img.setAttribute("data-fancybox", "gallery");
                img.classList.add("thumbnail");
            });
        }
    }

    function init() {
        addFancyboxAttributes();
        initializeFancybox();
        initializeSwiper();
    }

    // Run on initial load
    document.addEventListener("DOMContentLoaded", init);
    // Support Astro transitions
    document.addEventListener("astro:after-swap", init);
</script>
