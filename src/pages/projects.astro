---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Proyectos" description="Algunos proyectos realizados">
    <!-- incrustrar un video de youtube -->
    <!-- Hero Section -->
    <section class="relative overflow-hidden">
        <!-- Background texture -->
        <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-secondary/5 dark:from-primary/10 dark:to-secondary/10 pointer-events-none"></div>

        <div class="mx-auto max-w-[85rem] px-4 pt-8 pb-8 sm:px-6 lg:px-8 lg:pt-12">
            <!-- Label -->
            <div class="flex justify-center mb-6">
                <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-secondary/30 bg-secondary/10 text-secondary text-xs font-bold uppercase tracking-[0.25em]">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm0 18a8 8 0 110-16 8 8 0 010 16zm-1-13h2v6h-2zm0 8h2v2h-2z"/>
                    </svg>
                    Nuestra Experiencia en Movimiento
                </span>
            </div>

            <!-- Headline -->
            <h1 class="text-center text-4xl md:text-5xl font-black text-primary dark:text-white uppercase tracking-widest leading-[1.05] mb-6">
                Proyectos <span class="text-transparent bg-clip-text bg-gradient-to-r from-secondary to-primary/80">Destacados</span>
            </h1>

            <!-- Subtitle -->
            <p class="text-center text-xl text-neutral-500 dark:text-neutral-400 max-w-2xl mx-auto mb-8">
                Explore a través de estos registros visuales la calidad técnica y el compromiso que ponemos en cada obra hidrosanitaria y civil.
            </p>

            <!-- Animated underline -->
            <div class="mx-auto flex items-center justify-center gap-2">
                <div class="h-px w-16 bg-gradient-to-r from-transparent to-secondary/60"></div>
                <div class="h-1.5 w-10 rounded-full bg-gradient-to-r from-primary to-secondary"></div>
                <div class="h-px w-16 bg-gradient-to-l from-transparent to-secondary/60"></div>
            </div>
        </div>
    </section>

    <!-- Project Gallery -->
    <section class="mx-auto max-w-[85rem] px-4 py-12 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
            {[ 
                { 
                    title: "Instalación Hidrosanitaria Industrial", 
                    category: "Ingeniería", 
                    desc: "Implementación de sistemas de alta presión para complejo industrial en Cochabamba.",
                    video: "C1fWiKV9EZs?si=Bp7Cw8VArZsP0v1h"
                },
                { 
                    title: "Red de Gas Natural Domiciliario", 
                    category: "Gas Natural", 
                    desc: "Proyecto de expansión de red interna para edificio residencial multifamiliar.",
                    video: "C1fWiKV9EZs?si=Bp7Cw8VArZsP0v1h" // Usando el mismo como ejemplo
                }
            ].map((project, idx) => (
                <div class="group relative flex flex-col space-y-6">
                    <!-- Video Container -->
                    <div class="relative aspect-video w-full overflow-hidden rounded-[2.5rem] shadow-2xl bg-neutral-200 dark:bg-neutral-800 border border-neutral-200/50 dark:border-neutral-700/50 transition-all duration-500 group-hover:shadow-primary/20 group-hover:-translate-y-2">
                        <iframe
                            class="absolute top-0 left-0 w-full h-full"
                            src={`https://www.youtube.com/embed/${project.video}`}
                            title={project.title}
                            frameborder="0"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                            allowfullscreen>
                        </iframe>
                    </div>

                    <!-- Project Info -->
                    <div class="px-4">
                        <div class="flex items-center gap-x-3 mb-3">
                            <span class="px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-secondary border border-secondary/30 rounded-full">
                                {project.category}
                            </span>
                            <span class="text-xs text-neutral-400">PROYECTO 0{idx + 1}</span>
                        </div>
                        <h3 class="text-2xl md:text-3xl font-bold text-primary dark:text-neutral-100 uppercase tracking-widest mb-4 group-hover:text-secondary transition-colors">
                            {project.title}
                        </h3>
                        <p class="text-neutral-600 dark:text-neutral-400 leading-relaxed max-w-lg">
                            {project.desc}
                        </p>
                        
                        <div class="mt-8 flex items-center gap-x-6">
                            <div class="flex flex-col">
                                <span class="text-xl font-bold text-primary dark:text-neutral-200">100%</span>
                                <span class="text-[10px] uppercase font-bold text-neutral-500">Ejecución</span>
                            </div>
                            <div class="h-8 w-[1px] bg-neutral-200 dark:bg-neutral-800"></div>
                            <div class="flex flex-col">
                                <span class="text-xl font-bold text-primary dark:text-neutral-200">Garantía</span>
                                <span class="text-[10px] uppercase font-bold text-neutral-500">Total</span>
                            </div>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </section>

    <!-- Call to Action -->
    <section class="mx-auto max-w-[85rem] px-4 pb-24 sm:px-6 lg:px-8">
        <div class="bg-primary p-12 md:p-20 rounded-[3rem] text-center relative overflow-hidden shadow-2xl">
            <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-secondary/20 to-transparent opacity-50"></div>
            <div class="relative z-10 max-w-2xl mx-auto">
                <h2 class="text-3xl md:text-5xl font-bold text-white uppercase tracking-widest mb-8 leading-tight">
                    ¿Tiene un proyecto en mente?
                </h2>
                <p class="text-white/80 text-lg mb-10">
                    Nuestra experiencia técnica está a su disposición para garantizar soluciones hidrosanitarias de primer nivel.
                </p>
                <a 
                    href="/contact" 
                    class="inline-flex items-center justify-center px-10 py-5 text-sm font-bold text-primary uppercase tracking-widest bg-white rounded-full hover:bg-secondary hover:text-white transition-all duration-300 transform hover:scale-105"
                >
                    Iniciar Presupuesto
                </a>
            </div>
        </div>
    </section>
</BaseLayout>
