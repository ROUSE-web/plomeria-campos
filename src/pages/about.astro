---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import logo from "@images/nosotros.jpg";
import grupo from "@images/grupo.jpg";
---

<BaseLayout
    title="Nosotros | Plomería Campos"
    description="Conoce la historia, misión y valores de Plomería Campos, líderes en servicios hidrosanitarios en Bolivia desde 2009."
>
    <!-- Hero Story Section -->
    <section class="mx-auto max-w-[85rem] px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div>
                <h2
                    class="text-xs font-bold text-secondary uppercase tracking-[0.3em] mb-4"
                >
                    Nuestra Historia
                </h2>
                <h1
                    class="text-4xl md:text-5xl lg:text-6xl font-bold text-primary dark:text-neutral-100 uppercase tracking-tight leading-none mb-8"
                >
                    Desde 2015 forjando <span class="text-secondary"
                        >confianza</span
                    >
                </h1>
                <div
                    class="space-y-6 text-lg text-neutral-600 dark:text-neutral-300 leading-relaxed"
                >
                    <p>
                        PLOMERÍA CAMPOS nace en la ciudad de Cochabamba con una
                        visión clara: elevar los estándares de calidad en
                        servicios hidrosanitarios.
                    </p>
                    <p>
                        Lo que comenzó como un proyecto enfocado en
                        instalaciones de gas natural domiciliario, evolucionó
                        rápidamente. Tras detectar una necesidad crítica de
                        profesionalismo en el sector de la fontanería, nuestro
                        fundador Oscar Campos decidió profundizar sus
                        conocimientos y diversificar los servicios.
                    </p>
                    <p class="font-medium text-primary dark:text-secondary">
                        Hoy, somos un referente en soluciones técnicas
                        integrales, respaldados por un equipo altamente
                        capacitado y comprometido con la excelencia.
                    </p>
                </div>

                <div class="mt-10 flex gap-x-8">
                    <div class="flex flex-col">
                        <span
                            class="text-4xl font-bold text-primary dark:text-secondary"
                            >+10</span
                        >
                        <span
                            class="text-xs uppercase tracking-widest font-bold text-neutral-500"
                            >Años de Trayectoria</span
                        >
                    </div>
                    <div class="w-[1px] bg-neutral-200 dark:bg-neutral-800">
                    </div>
                    <div class="flex flex-col">
                        <span
                            class="text-4xl font-bold text-primary dark:text-secondary"
                            >+500</span
                        >
                        <span
                            class="text-xs uppercase tracking-widest font-bold text-neutral-500"
                            >Proyectos Exitosos</span
                        >
                    </div>
                </div>
            </div>

            <div class="relative space-y-6">
                <div
                    class="absolute -top-4 -left-4 w-24 h-24 bg-tertiary/20 rounded-full blur-2xl"
                >
                </div>
                <div
                    class="absolute -bottom-4 -right-4 w-32 h-32 bg-secondary/10 rounded-full blur-3xl"
                >
                </div>

                <!-- Full-width Team Photo -->
                <div class="relative z-10">
                    <Image
                        class="w-full h-full object-cover rounded-3xl shadow-xl border border-tertiary/20"
                        src={grupo}
                        alt="Equipo de Trabajo"
                    />
                </div>

                <!-- Oscar Photo & Quote Side-by-Side -->
                <div
                    class="grid grid-cols-1 md:grid-cols-2 gap-6 items-center relative z-10"
                >
                    <div
                        class="overflow-hidden rounded-2xl shadow-lg border border-tertiary/20"
                    >
                        <Image
                            class="w-full h-64 object-cover transform scale-150 object-top"
                            src={logo}
                            alt="Oscar Campos - Fundador"
                        />
                    </div>
                    <div
                        class="bg-white dark:bg-neutral-900/60 border border-tertiary/50 dark:border-neutral-800 p-6 rounded-2xl shadow-xl backdrop-blur-sm h-full flex flex-col justify-center"
                    >
                        <p
                            class="text-sm italic text-neutral-600 dark:text-neutral-400 leading-relaxed"
                        >
                            &quot;Nuestra prioridad no es solo solucionar un
                            problema técnico, sino construir relaciones
                            duraderas basadas en la confianza y la
                            calidad.&quot;
                        </p>
                        <div class="mt-4 flex items-center gap-x-3">
                            <div
                                class="h-8 w-8 rounded-full bg-primary flex items-center justify-center text-white font-bold text-xs flex-shrink-0"
                            >
                                OC
                            </div>
                            <div>
                                <p
                                    class="text-xs font-bold text-primary dark:text-secondary uppercase"
                                >
                                    Oscar Campos
                                </p>
                                <p class="text-[10px] text-neutral-500">
                                    Fundador
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Mission & Vision Cards (Modern Grid) -->
    <section
        class="py-24 border-y border-tertiary/30 dark:border-neutral-800/50"
    >
        <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                <!-- Misión -->
                <div
                    class="group bg-white dark:bg-neutral-900/40 p-10 rounded-[2.5rem] border border-transparent hover:border-tertiary transition-all duration-500 hover:shadow-2xl"
                >
                    <div class="flex items-center gap-x-6 mb-8">
                        <div
                            class="p-5 bg-tertiary/30 dark:bg-secondary/10 rounded-3xl group-hover:scale-110 transition-transform duration-500"
                        >
                            <svg
                                class="size-10 text-primary dark:text-secondary"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="1.5"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.98 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699-7.38a14.98 14.98 0 0111.469-3.38m-14.168 14.17A14.98 14.98 0 011.63 21.631"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="text-3xl font-bold text-primary dark:text-neutral-100 uppercase tracking-tighter"
                        >
                            Misión
                        </h3>
                    </div>
                    <p
                        class="text-xl text-neutral-600 dark:text-neutral-400 leading-relaxed"
                    >
                        Ofrecemos servicios de fontanería y obras civiles con un
                        enfoque inquebrantable en la **calidad técnica** y la
                        **eficiencia**, garantizando soluciones duraderas para
                        el desarrollo de Bolivia.
                    </p>
                </div>

                <!-- Visión -->
                <div
                    class="group bg-white dark:bg-neutral-900/40 p-10 rounded-[2.5rem] border border-transparent hover:border-tertiary transition-all duration-500 hover:shadow-2xl"
                >
                    <div class="flex items-center gap-x-6 mb-8">
                        <div
                            class="p-5 bg-tertiary/30 dark:bg-secondary/10 rounded-3xl group-hover:scale-110 transition-transform duration-500"
                        >
                            <svg
                                class="size-10 text-primary dark:text-secondary"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="1.5"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.43 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"
                                ></path>
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                        </div>
                        <h3
                            class="text-3xl font-bold text-primary dark:text-neutral-100 uppercase tracking-tighter"
                        >
                            Visión
                        </h3>
                    </div>
                    <p
                        class="text-xl text-neutral-600 dark:text-neutral-400 leading-relaxed"
                    >
                        Ser la empresa líder y referente nacional en ingeniería
                        hidrosanitaria, destacando por nuestra **capacidad de
                        innovación** y el impacto positivo en cada
                        infraestructura que intervenimos.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Valores Section (Modern Corporate Grid) -->
    <section
        class="mx-auto max-w-[85rem] px-4 py-16 sm:px-6 lg:px-8"
    >
        <div class="max-w-2xl mx-auto text-center mb-16">
            <h2
                class="text-xs font-bold text-secondary uppercase tracking-[0.4em] mb-4"
            >
                Nuestra Identidad
            </h2>
            <h3
                class="text-4xl md:text-5xl font-bold text-primary dark:text-neutral-100 uppercase tracking-tight"
            >
                Valores Corporativos
            </h3>
            <p class="mt-4 text-neutral-500 dark:text-neutral-400">
                Los pilares que sostienen cada uno de nuestros proyectos y
                garantizan su éxito.
            </p>
            <div
                class="mt-8 h-1.5 w-32 bg-gradient-to-r from-primary to-secondary mx-auto rounded-full"
            >
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            {
                [
                    {
                        v: "Disciplina",
                        d: "Rigor técnico y puntualidad en cada proceso de obra.",
                        i: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />`,
                    },
                    {
                        v: "Proactividad",
                        d: "Anticipamos desafíos para ofrecer soluciones antes de que surjan problemas.",
                        i: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />`,
                    },
                    {
                        v: "Responsabilidad",
                        d: "Compromiso absoluto con la seguridad y el patrimonio de nuestros clientes.",
                        i: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />`,
                    },
                    {
                        v: "Buena atención",
                        d: "Trato humano, empático y comunicación constante en cada etapa.",
                        i: `<path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />`,
                    },
                    {
                        v: "Cumplimiento",
                        d: "Respeto sagrado por los plazos de entrega y presupuestos acordados.",
                        i: `<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zm6.75-4.5h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V15zm0 2.25h.008v.008h-.008v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z" />`,
                    },
                    {
                        v: "Seriedad",
                        d: "Transparencia legal y ética profesional en todas nuestras operaciones.",
                        i: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />`,
                    },
                    {
                        v: "Garantía",
                        d: "Respaldo técnico integral y compromiso post-servicio garantizado.",
                        i: `<path stroke-linecap="round" stroke-linejoin="round" d="M10.125 2.25h3.75a.625.625 0 01.625.625v3.125h-5V2.875a.625.625 0 01.625-.625zm-6 4.375c0-.69.56-1.25 1.25-1.25h13.25c.69 0 1.25.56 1.25 1.25v1.25H4.125v-1.25zm1.25 2.5h11.5a.625.625 0 01.625.625v10.125a1.875 1.875 0 01-1.875 1.875H5.75A1.875 1.875 0 013.875 19.625V9.75a.625.625 0 01.625-.625z" />`,
                    },
                    {
                        v: "Profesionalismo",
                        d: "Equipo altamente calificado con formación continua y certificada.",
                        i: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.174L15.44 2.184a.75.75 0 011.15.514l.522 5.404a2.25 2.25 0 01-.73 1.896L6.036 17.293a.75.75 0 01-1.224-.42l-1.068-5.46a2.25 2.25 0 01.516-1.239zM4.26 10.174l-.94 5.922m.94-5.922l.522 5.404m0 0l-1.462 7.382" />`,
                    },
                ].map((item, idx) => (
                    <div class="relative group bg-neutral-50 dark:bg-neutral-900/40 p-8 rounded-[2rem] border border-neutral-200 dark:border-neutral-800 transition-all duration-500 hover:bg-white dark:hover:bg-neutral-900 hover:shadow-[0_20px_50px_rgba(0,0,0,0.05)] dark:hover:shadow-[0_20px_50px_rgba(0,0,0,0.3)] hover:-translate-y-2 overflow-hidden">
                        <div class="absolute -right-4 -bottom-4 text-9xl font-black text-neutral-200/20 dark:text-neutral-800/20 group-hover:text-primary/10 transition-colors pointer-events-none">
                            {idx + 1}
                        </div>
                        <div class="relative z-10">
                            <div class="mb-6 inline-flex p-4 bg-white dark:bg-neutral-800 rounded-2xl shadow-sm border border-neutral-100 dark:border-neutral-700 group-hover:bg-primary group-hover:border-primary transition-all duration-500">
                                <svg
                                    class="size-8 text-primary group-hover:text-white transition-colors"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="1.5"
                                >
                                    <Fragment set:html={item.i} />
                                </svg>
                            </div>
                            <h4 class="text-xl font-bold text-primary dark:text-neutral-100 uppercase tracking-tight mb-3">
                                {item.v}
                            </h4>
                            <p class="text-neutral-500 dark:text-neutral-400 text-sm leading-relaxed">
                                {item.d}
                            </p>
                        </div>
                    </div>
                ))
            }
        </div>
    </section>
</BaseLayout>
