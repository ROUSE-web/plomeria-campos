---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import logo from "@images/nosotros.jpg";
import grupo from "@images/grupo.jpg";
import grupo2 from "@images/grupo2.webp";
---

<BaseLayout
    title="Nosotros | Plomería Campos"
    description="Conoce la historia, misión y valores de Plomería Campos, líderes en servicios hidrosanitarios en Bolivia desde 2009."
>

    <!-- ─── HERO ───────────────────────────────────────────────── -->
    <section class="relative overflow-hidden">
        <!-- Background texture -->
        <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-secondary/5 dark:from-primary/10 dark:to-secondary/10 pointer-events-none"></div>

        <div class="mx-auto max-w-[85rem] px-4 pt-8 pb-8 sm:px-6 lg:px-8 lg:pt-12">
            <!-- Label -->
            <div class="flex justify-center mb-6">
                <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-secondary/30 bg-secondary/10 text-secondary text-xs font-bold uppercase tracking-[0.25em]">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm0 18a8 8 0 110-16 8 8 0 010 16zm-1-13h2v6h-2zm0 8h2v2h-2z"/>
                    </svg>
                    Sobre Nosotros
                </span>
            </div>

            <!-- Headline -->
            <h1 class="text-center text-4xl md:text-5xl font-black text-primary dark:text-white uppercase tracking-widest leading-[1.05] mb-6">
                Desde 2015 forjando<br/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-secondary to-primary/80">confianza</span>
            </h1>

            <!-- Subtitle -->
            <p class="text-center text-xl text-neutral-500 dark:text-neutral-400 max-w-2xl mx-auto mb-16">
                Empresa boliviana líder en servicios hidrosanitarios, con más de una década elevando los estándares del sector.
            </p>

            <!-- Stats strip -->
            <div class="grid grid-cols-3 gap-4 max-w-2xl mx-auto mb-20">
                {[
                    { n: "+10", l: "Años" },
                    { n: "+500", l: "Proyectos" },
                    { n: "100%", l: "Garantizados" },
                ].map(s => (
                    <div class="text-center p-6 rounded-2xl bg-white dark:bg-neutral-900/60 border border-neutral-100 dark:border-neutral-800 shadow-sm">
                        <div class="text-3xl md:text-4xl font-black text-primary dark:text-secondary">{s.n}</div>
                        <div class="text-xs uppercase tracking-widest font-bold text-neutral-400 mt-1">{s.l}</div>
                    </div>
                ))}
            </div>

            <!-- ─── REARRANGED IMAGE GALLERY (Full Images) ────────────────────────── -->
            <div class="space-y-6">
                <!-- Top Row: Nosotros & Grupo side by side -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Founder Image (logo/nosotros) -->
                    <div class="relative rounded-[2.5rem] overflow-hidden group shadow-xl border border-neutral-100 dark:border-neutral-800 h-full">
                        <Image
                            class="w-full h-full object-cover object-top scale-[1.3] transition-transform duration-700 group-hover:scale-[1.4]"
                            src={logo}
                            alt="Oscar Campos — Fundador"
                        />
                        <!-- Glassmorphism Quote Card -->
                        <div class="absolute bottom-6 left-6 right-6 p-5 bg-primary/40 backdrop-blur-xl border border-white/20 rounded-[2rem] shadow-2xl translate-y-4 group-hover:translate-y-0 transition-all duration-500">
                            <p class="text-white text-[10px] italic leading-relaxed mb-3">
                                "Construimos relaciones duraderas basadas en la confianza."
                            </p>
                            <div class="flex items-center gap-2">
                                <div class="w-7 h-7 rounded-full bg-secondary flex items-center justify-center text-[9px] font-black text-primary flex-shrink-0">OC</div>
                                <div>
                                    <p class="text-white text-[9px] font-bold uppercase tracking-wider">Oscar Campos</p>
                                    <p class="text-white/70 text-[8px]">Fundador</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Team Photo (grupo) -->
                    <div class="relative rounded-[2.5rem] overflow-hidden group shadow-xl border border-neutral-100 dark:border-neutral-800">
                        <Image
                            class="w-full h-auto transition-transform duration-700 group-hover:scale-[1.02]"
                            src={grupo}
                            alt="Equipo de Trabajo Plomería Campos"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
                        <div class="absolute bottom-6 left-6 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-500">
                            <span class="px-4 py-2 bg-black/40 backdrop-blur-md border border-white/20 rounded-full text-[10px] font-bold text-white uppercase tracking-widest shadow-lg">
                                Compromiso Técnico
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Bottom Row: Grupo2 Full Width -->
                <div class="relative rounded-[2.5rem] overflow-hidden group shadow-2xl border border-neutral-100 dark:border-neutral-800">
                    <Image
                        class="w-full h-auto transition-transform duration-700 group-hover:scale-[1.02]"
                        src={grupo2}
                        alt="Equipo de Plomería Campos en plena acción"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-primary/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
                    <div class="absolute bottom-8 left-8 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-500">
                        <span class="px-5 py-2.5 bg-white/20 backdrop-blur-md border border-white/30 rounded-full text-xs font-bold text-white uppercase tracking-widest shadow-lg">
                            Nuestro equipo en acción
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ─── STORY ─────────────────────────────────────────────── -->
    <section class="mx-auto max-w-[85rem] px-4 py-24 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <!-- Text -->
            <div>
                <h2 class="text-xs font-bold text-secondary uppercase tracking-[0.4em] mb-4">Nuestra Historia</h2>
                <h3 class="text-4xl md:text-5xl font-black text-primary dark:text-white uppercase tracking-tight mb-8">
                    Una empresa<br/>
                    <span class="text-secondary">con propósito</span>
                </h3>
                <div class="space-y-5 text-lg text-neutral-600 dark:text-neutral-300 leading-relaxed">
                    <p>
                        PLOMERÍA CAMPOS nace en la ciudad de Cochabamba con una visión clara: elevar los estándares de calidad en servicios hidrosanitarios.
                    </p>
                    <p>
                        Lo que comenzó como un proyecto enfocado en instalaciones de gas natural domiciliario, evolucionó rápidamente hacia un servicio integral de fontanería profesional.
                    </p>
                    <p class="font-semibold text-primary dark:text-secondary">
                        Hoy somos referente en soluciones técnicas integrales, respaldados por un equipo altamente capacitado y comprometido con la excelencia.
                    </p>
                </div>
            </div>

            <!-- Mission & Vision cards -->
            <div class="grid grid-cols-1 gap-6">
                <!-- Misión -->
                <div class="group relative overflow-hidden p-8 rounded-[2rem] bg-white dark:bg-neutral-900/50 border border-neutral-100 dark:border-neutral-800 hover:border-secondary/30 hover:shadow-xl transition-all duration-500">
                    <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-primary to-secondary rounded-l-[2rem]"></div>
                    <div class="flex items-start gap-5">
                        <div class="flex-shrink-0 p-3 bg-secondary/10 rounded-2xl">
                            <svg class="w-7 h-7 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.98 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699-7.38a14.98 14.98 0 0111.469-3.38m-14.168 14.17A14.98 14.98 0 011.63 21.631"/>
                            </svg>
                        </div>
                        <div>
                            <h4 class="text-xl font-black text-primary dark:text-white uppercase tracking-tight mb-2">Misión</h4>
                            <p class="text-neutral-500 dark:text-neutral-400 leading-relaxed">
                                Ofrecer servicios de fontanería y obras civiles con calidad técnica y eficiencia garantizadas, impulsando el desarrollo de Bolivia.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Visión -->
                <div class="group relative overflow-hidden p-8 rounded-[2rem] bg-white dark:bg-neutral-900/50 border border-neutral-100 dark:border-neutral-800 hover:border-secondary/30 hover:shadow-xl transition-all duration-500">
                    <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-secondary to-primary rounded-l-[2rem]"></div>
                    <div class="flex items-start gap-5">
                        <div class="flex-shrink-0 p-3 bg-primary/10 dark:bg-secondary/10 rounded-2xl">
                            <svg class="w-7 h-7 text-primary dark:text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.43 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                        </div>
                        <div>
                            <h4 class="text-xl font-black text-primary dark:text-white uppercase tracking-tight mb-2">Visión</h4>
                            <p class="text-neutral-500 dark:text-neutral-400 leading-relaxed">
                                Ser la empresa líder en ingeniería hidrosanitaria nacional, destacando por innovación e impacto positivo en cada infraestructura.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ─── VALUES ────────────────────────────────────────────── -->
    <section class="border-t border-neutral-100 dark:border-neutral-800">
        <div class="mx-auto max-w-[85rem] px-4 py-24 sm:px-6 lg:px-8">
            <!-- Header -->
            <div class="max-w-2xl mx-auto text-center mb-16">
                <h2 class="text-xs font-bold text-secondary uppercase tracking-[0.4em] mb-4">Nuestra Identidad</h2>
                <h3 class="text-4xl md:text-5xl font-black text-primary dark:text-white uppercase tracking-tight">
                    Valores Corporativos
                </h3>
                <p class="mt-4 text-neutral-500 dark:text-neutral-400 text-lg">
                    Los pilares que sostienen cada proyecto y garantizan su éxito.
                </p>
                <div class="mt-6 flex items-center justify-center gap-2">
                    <div class="h-px w-12 bg-gradient-to-r from-transparent to-secondary/60"></div>
                    <div class="h-1.5 w-8 rounded-full bg-gradient-to-r from-primary to-secondary"></div>
                    <div class="h-px w-12 bg-gradient-to-l from-transparent to-secondary/60"></div>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                {
                    [
                        { v: "Disciplina",       d: "Rigor técnico y puntualidad en cada proceso de obra.", i: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />` },
                        { v: "Proactividad",     d: "Anticipamos desafíos para ofrecer soluciones antes de que surjan problemas.", i: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />` },
                        { v: "Responsabilidad",  d: "Compromiso absoluto con la seguridad y el patrimonio de nuestros clientes.", i: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />` },
                        { v: "Buena atención",   d: "Trato humano, empático y comunicación constante en cada etapa.", i: `<path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />` },
                        { v: "Cumplimiento",     d: "Respeto sagrado por los plazos de entrega y presupuestos acordados.", i: `<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zm6.75-4.5h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V15zm0 2.25h.008v.008h-.008v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z" />` },
                        { v: "Seriedad",         d: "Transparencia legal y ética profesional en todas nuestras operaciones.", i: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />` },
                        { v: "Garantía",         d: "Respaldo técnico integral y compromiso post-servicio garantizado.", i: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />` },
                        { v: "Profesionalismo",  d: "Equipo altamente calificado con formación continua y certificada.", i: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />` },
                    ].map((item, idx) => (
                        <div class="relative group bg-neutral-50 dark:bg-neutral-900/40 p-7 rounded-[1.75rem] border border-neutral-200 dark:border-neutral-800 transition-all duration-500 hover:bg-white dark:hover:bg-neutral-900 hover:shadow-[0_20px_50px_rgba(0,0,0,0.06)] dark:hover:shadow-[0_20px_50px_rgba(0,0,0,0.3)] hover:-translate-y-1.5 overflow-hidden">
                            <!-- Large index watermark -->
                            <div class="absolute -right-3 -bottom-3 text-8xl font-black text-neutral-100/60 dark:text-neutral-800/50 group-hover:text-secondary/10 transition-colors pointer-events-none select-none">
                                {idx + 1}
                            </div>
                            <div class="relative z-10">
                                <!-- Icon container -->
                                <div class="mb-5 inline-flex p-3.5 bg-white dark:bg-neutral-800 rounded-2xl shadow-sm border border-neutral-100 dark:border-neutral-700 group-hover:bg-primary group-hover:border-primary transition-all duration-500">
                                    <svg class="size-7 text-secondary group-hover:text-white transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                        <Fragment set:html={item.i} />
                                    </svg>
                                </div>
                                <!-- Title -->
                                <h4 class="text-lg font-black text-primary dark:text-neutral-100 uppercase tracking-tight mb-2">
                                    {item.v}
                                </h4>
                                <!-- Description -->
                                <p class="text-neutral-500 dark:text-neutral-400 text-sm leading-relaxed">
                                    {item.d}
                                </p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

</BaseLayout>
