---
import type { CollectionEntry } from "astro:content";
import Icon from "@components/ui/icons/icon.astro";
import Image from "@components/ui/images/Image.astro";

const { blog } = Astro.props;

interface Props {
    blog: CollectionEntry<"posts">;
}
---

<a
    class="group relative flex flex-col h-full bg-white dark:bg-neutral-900/40 border border-neutral-200 dark:border-neutral-800 rounded-[2rem] overflow-hidden transition-all duration-500 hover:shadow-[0_30px_60px_rgba(0,0,0,0.1)] dark:hover:shadow-[0_30px_60px_rgba(0,0,0,0.5)] hover:-translate-y-2 outline-none focus-visible:ring-2 focus-visible:ring-primary"
    href={`/services/${blog.slug}/`}
    data-astro-prefetch
>
    <!-- Image Section -->
    <div class="relative overflow-hidden aspect-[16/10]">
        <Image
            class="w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-110 group-hover:brightness-75"
            src={blog.data.banner}
            alt={blog.data.title}
            format="avif"
            loading="eager"
            width="800"
            height="500"
        />
        <!-- Overlay -->
        <div class="absolute inset-0 bg-primary/40 backdrop-blur-[2px] opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-center justify-center p-8">
            <span class="px-6 py-3 border-2 border-white text-white font-bold text-xs uppercase tracking-[0.3em] rounded-full transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                Ver Detalles
            </span>
        </div>
    </div>

    <!-- Content Section -->
    <div class="p-8 flex flex-col grow relative">
        <!-- Decoration: Number or Icon Background could go here -->
        
        <h3 class="text-2xl font-bold text-primary dark:text-neutral-100 uppercase tracking-tighter leading-tight group-hover:text-secondary transition-colors duration-300">
            {blog.data.title}
        </h3>

        <p class="mt-4 text-neutral-500 dark:text-neutral-400 text-sm leading-relaxed line-clamp-3 flex-grow">
            {blog.data.description}
        </p>

        <div class="mt-6 flex items-center gap-x-2 text-[10px] font-bold text-secondary uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-all duration-500 transform translate-x-[-10px] group-hover:translate-x-0">
            <span>Explorar Servicio</span>
            <Icon name="arrowRightStatic" class="size-3" />
        </div>
    </div>
</a>
