---
import type { CollectionEntry } from "astro:content";
import Icon from "@components/ui/icons/icon.astro";
import Image from "@components/ui/images/Image.astro";

const { blog } = Astro.props;

interface Props {
    blog: CollectionEntry<"posts">;
}
---

<a
    class="group flex flex-col h-full bg-white border border-tertiary rounded-2xl p-4 transition-all duration-300 hover:shadow-xl hover:border-secondary/50 outline-none focus-visible:ring-2 focus-visible:ring-primary dark:bg-neutral-900/40 dark:border-neutral-800 dark:hover:border-secondary/30"
    href={`/services/${blog.slug}/`}
    data-astro-prefetch
>
    <div class="relative overflow-hidden rounded-xl aspect-[16/10]">
        <Image
            class="w-full h-full object-cover rounded-xl transition duration-700 ease-in-out group-hover:scale-110"
            src={blog.data.banner}
            alt={blog.data.title}
            format="avif"
            loading="eager"
            width="800"
            height="500"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-primary/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
             <span class="text-white font-bold text-lg">Explorar Servicio</span>
        </div>
    </div>

    <div class="mt-5 flex flex-col grow">
        <h3
            class="text-xl font-bold text-primary group-hover:text-secondary transition-colors duration-300 dark:text-neutral-200 dark:group-hover:text-secondary xl:text-2xl"
        >
            {blog.data.title}
        </h3>

        <p class="mt-3 text-neutral-600 line-clamp-3 dark:text-neutral-300 flex-grow">
            {blog.data.description}
        </p>

        <div
            class="mt-6 inline-flex items-center gap-x-2 font-bold text-primary dark:text-secondary group-hover:gap-x-3 transition-all duration-300"
        >
            <span class="border-b-2 border-transparent group-hover:border-secondary">Ver más</span>
            <Icon name="arrowRightStatic" />
        </div>
    </div>
</a>
