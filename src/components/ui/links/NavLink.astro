---
const { url, name } = Astro.props;

interface Props {
    url: string;
    name: string;
}
---

<a
    id={url === "/" ? "home" : url.replace("/", "")}
    href={url}
    data-astro-prefetch
    class="rounded-lg text-base font-medium text-neutral-600 outline-none ring-zinc-500 hover:text-primary transition-colors duration-300 focus-visible:ring dark:text-neutral-200 dark:ring-zinc-200 dark:hover:text-secondary dark:focus:outline-none md:py-3 md:text-sm xl:text-base"
>
    {name}
</a>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const url = window.location.pathname.replace("//", "");
        let navId = "home";

        if (url !== "/") {
            navId = url.replace("/", "");
        }

        const nav = document.getElementById(navId);
        if (nav) {
            nav.classList.remove(
                "text-neutral-600",
                "dark:text-neutral-200",
                "hover:text-primary",
                "dark:hover:text-secondary"
            );
            nav.classList.add("text-primary", "dark:text-secondary", "font-bold");
            nav.setAttribute("aria-current", "page");
        }
    });
</script>
