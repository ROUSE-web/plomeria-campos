---
import BrandLogo2 from "@components/ui/logos/BrandLogo2.astro";
import { SITE } from "@/config";
import Icon from "@components/ui/icons/icon.astro";

var today = new Date();
var year = today.getFullYear();
---

<footer class="w-full bg-white border-t border-tertiary/50 dark:bg-[#050a11] dark:border-neutral-800">
    <div
        class="mx-auto w-full max-w-[85rem] px-4 py-12 sm:px-6 lg:px-8 2xl:max-w-screen-2xl"
    >
        <div class="flex flex-col items-center justify-between gap-y-8 md:flex-row md:gap-y-0">
            <div class="flex items-center gap-x-4">
                <BrandLogo2 class="h-12 w-auto rounded-lg" />
                <div class="flex flex-col">
                    <span class="text-xl font-bold text-primary dark:text-neutral-100 uppercase tracking-tighter">{SITE.title}</span>
                    <span class="text-xs text-neutral-500 uppercase tracking-widest">Profesionalismo y Durabilidad</span>
                </div>
            </div>

            <div class="flex items-center gap-x-6">
                <a
                    href="https://www.facebook.com/plomeriacampos"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group"
                >
                    <div class="flex items-center justify-center size-10 rounded-full bg-neutral-100 transition-all duration-300 group-hover:bg-[#1877F2] group-hover:text-white text-neutral-600 dark:bg-neutral-800 dark:group-hover:bg-[#1877F2]">
                        <Icon name="facebook" class="size-5" />
                    </div>
                </a>
                <a
                    href="https://wa.me/59178300509/?text=Hola%20Plomería%20Campos%2C%20me%20gustaría%20cotizar%20un%20servicio"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group"
                >
                    <div class="flex items-center justify-center size-10 rounded-full bg-neutral-100 transition-all duration-300 group-hover:bg-[#25D366] group-hover:text-white text-neutral-600 dark:bg-neutral-800 dark:group-hover:bg-[#25D366]">
                        <Icon name="whatsapp" class="size-5" />
                    </div>
                </a>
                <a
                    href="mailto:serviplom29@gmail.com"
                    class="group"
                >
                    <div class="flex items-center justify-center size-10 rounded-full bg-neutral-100 transition-all duration-300 group-hover:bg-primary group-hover:text-white text-neutral-600 dark:bg-neutral-800 dark:group-hover:bg-primary">
                        <Icon name="email" class="size-5" />
                    </div>
                </a>
                <a
                    href="https://www.youtube.com/@Plomer%C3%ADaCampos"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group"
                >
                    <div class="flex items-center justify-center size-10 rounded-full bg-neutral-100 transition-all duration-300 group-hover:bg-[#FF0000] group-hover:text-white text-neutral-600 dark:bg-neutral-800 dark:group-hover:bg-[#FF0000]">
                        <Icon name="youtube" class="size-5" />
                    </div>
                </a>
            </div>
        </div>

        <div class="mt-12 pt-8 border-t border-tertiary/30 dark:border-neutral-800/50 flex flex-col md:flex-row justify-between items-center gap-y-4">
            <p class="text-sm text-neutral-500 dark:text-neutral-400">
                © {year} {SITE.title}. Todos los derechos reservados. | Diseñado por <a href="https://renovatecreativo.com" target="_blank" rel="noopener noreferrer" class="font-bold text-neutral-600 dark:text-neutral-300 hover:text-primary transition-colors">renovatecreativo.com</a>
            </p>
            <div class="flex gap-x-6 text-sm font-medium text-neutral-500">
                <a href="/about" class="hover:text-primary transition-colors">Nosotros</a>
                <a href="/services" class="hover:text-primary transition-colors">Servicios</a>
                <a href="/contact" class="hover:text-primary transition-colors">Contacto</a>
            </div>
        </div>
    </div>
</footer>
